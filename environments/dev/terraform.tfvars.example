project     = "portfolio"
environment = "dev"
vpc_cidr    = "10.0.0.0/16"

availability_zones = [
  "ap-northeast-1a",
  "ap-northeast-1c"
]

public_subnet_cidrs = [
  "10.0.1.0/24",  
  "10.0.2.0/24"   
]

private_app_subnet_cidrs = [
  "10.0.10.0/24",
  "10.0.11.0/24"
]

private_db_subnet_cidrs = [
  "10.0.20.0/24",
  "10.0.21.0/24"
]

# データベース設定
db_name     = "portfoliodevdb"
db_username = "admin"
db_password = "<YOUR_DB_PASSWORD>"  # 実運用時は適切な認証情報管理を実装
